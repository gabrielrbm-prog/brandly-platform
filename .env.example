# Banco de Dados
DATABASE_URL=postgres://user:password@localhost:5432/brandly

# API
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# JWT
JWT_SECRET=change-me-in-production

# LLM — Geracao de Roteiros (pelo menos uma key necessaria)
LLM_PROVIDER=claude  # claude | openai
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o  # opcional, default gpt-4o

# Phyllo — Integracao Instagram/TikTok
PHYLLO_CLIENT_ID=your-phyllo-client-id
PHYLLO_CLIENT_SECRET=your-phyllo-client-secret
PHYLLO_ENVIRONMENT=sandbox  # sandbox | production

# Redis (para filas BullMQ)
REDIS_URL=redis://localhost:6379

GOOGLE_SHEETS_WEBHOOK_SECRET=your-secret-here

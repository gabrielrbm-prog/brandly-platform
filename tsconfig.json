{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022"
    ],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@brandly/core": [
        "packages/core/src"
      ],
      "@brandly/api": [
        "packages/api/src"
      ],
      "@brandly/bonus-engine": [
        "packages/bonus-engine/src"
      ],
      "@brandly/shared": [
        "packages/shared/src"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "dist"
  ]
}
